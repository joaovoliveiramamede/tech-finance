<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.techfinance.pessoal.desktop.controller.CreateAccountController"
            styleClass="register-root">

    <center>
        <VBox alignment="CENTER">
            <VBox styleClass="register-card" spacing="16">
                <padding>
                    <Insets top="32" right="32" bottom="32" left="32"/>
                </padding>

                <Label text="Primeira conta"
                       styleClass="register-title"/>

                <Label fx:id="welcomeLabel"
                       text="Olá!"
                       styleClass="register-subtitle"/>

                <Label text="Crie sua primeira conta para começar a usar o painel."
                       wrapText="true"
                       styleClass="register-subtitle"/>

                <TextField fx:id="nameField"
                           promptText="Nome da conta"
                           styleClass="register-field"/>

                <TextField fx:id="balanceField"
                           promptText="Saldo inicial (ex: 1500.00)"
                           styleClass="register-field"/>

                <Label fx:id="errorLabel"
                       visible="false"
                       managed="false"
                       styleClass="error-label"/>

                <Button text="Criar conta e continuar"
                        onAction="#handleCreate"
                        styleClass="register-button"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
