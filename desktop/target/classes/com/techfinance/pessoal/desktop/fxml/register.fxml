<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.techfinance.pessoal.desktop.controller.RegisterController"
            styleClass="auth-root">

    <center>
        <VBox alignment="CENTER" spacing="24">

            <VBox styleClass="auth-card" spacing="16" maxWidth="460">

                <padding>
                    <Insets top="32" right="32" bottom="32" left="32"/>
                </padding>

                <VBox spacing="6">
                    <Label text="Criar conta" styleClass="auth-title"/>
                    <Label text="Comece a organizar suas finanças pessoais." styleClass="auth-subtitle"/>
                </VBox>

                <VBox spacing="10">
                    <Label text="Nome" styleClass="field-label"/>
                    <TextField fx:id="nameField" promptText="Seu nome"/>
                </VBox>

                <VBox spacing="10">
                    <Label text="E-mail" styleClass="field-label"/>
                    <TextField fx:id="emailField" promptText="seuemail@email.com"/>
                </VBox>

                <VBox spacing="10">
                    <Label text="Senha" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField" promptText="Mínimo 6 caracteres"/>
                </VBox>

                <VBox spacing="10">
                    <Label text="Confirmar senha" styleClass="field-label"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Repita sua senha"/>
                </VBox>

                <Label fx:id="errorLabel" styleClass="error-label" visible="false" managed="false"/>

                <Button text="Cadastrar" onAction="#handleRegister" styleClass="primary-button" maxWidth="Infinity"/>

                <Button text="Já tenho uma conta" onAction="#goToLogin" styleClass="link-button" maxWidth="Infinity"/>

            </VBox>

        </VBox>
    </center>

</BorderPane>