<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.techfinance.pessoal.desktop.controller.RegisterController"
           styleClass="auth-root">

    <VBox alignment="CENTER">

        <VBox styleClass="auth-card" spacing="16">

            <padding>
                <Insets top="32" right="32" bottom="32" left="32"/>
            </padding>

            <Label text="Criar conta"
                   styleClass="auth-title"/>

            <Label text="Comece a organizar suas finanças"
                   styleClass="auth-subtitle"/>

            <TextField fx:id="nameField"
                       promptText="Nome"
                       styleClass="auth-field"/>

            <TextField fx:id="usernameField"
                       promptText="Usuário"
                       styleClass="auth-field"/>

            <PasswordField fx:id="passwordField"
                           promptText="Senha"
                           styleClass="auth-field"/>

            <Label fx:id="errorLabel"
                   visible="false"
                   managed="false"
                   styleClass="error-label"/>

            <Button text="Cadastrar"
                    maxWidth="Infinity"
                    onAction="#handleRegister"
                    styleClass="auth-button"/>

            <Button text="Já tenho conta"
                    maxWidth="Infinity"
                    onAction="#goToLogin"
                    styleClass="auth-link"/>

        </VBox>

    </VBox>

</StackPane>