<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" spacing="20" styleClass="page">
    <padding>
        <Insets top="28" right="32" bottom="32" left="32"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label text="Transações" styleClass="page-title"/>
            <Label text="Lançamentos de receitas e despesas" styleClass="page-subtitle"/>
        </VBox>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Nova transação" styleClass="primary-button"/>
    </HBox>

    <HBox spacing="12" styleClass="filter-bar">
        <TextField promptText="Buscar por descrição" HBox.hgrow="ALWAYS"/>
        <ComboBox promptText="Tipo" prefWidth="150"/>
        <ComboBox promptText="Conta" prefWidth="180"/>
        <ComboBox promptText="Categoria" prefWidth="180"/>
    </HBox>

    <TableView VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn text="Data" prefWidth="160"/>
            <TableColumn text="Descrição" prefWidth="300"/>
            <TableColumn text="Conta" prefWidth="180"/>
            <TableColumn text="Categoria" prefWidth="180"/>
            <TableColumn text="Tipo" prefWidth="120"/>
            <TableColumn text="Valor" prefWidth="140"/>
        </columns>
    </TableView>
</VBox>
