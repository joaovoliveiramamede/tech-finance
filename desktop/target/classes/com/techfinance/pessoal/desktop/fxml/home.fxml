<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" spacing="24" styleClass="page">
    <padding>
        <Insets top="28" right="32" bottom="32" left="32"/>
    </padding>

    <VBox spacing="4">
        <Label text="Home" styleClass="page-title"/>
        <Label text="Resumo geral das suas finanças" styleClass="page-subtitle"/>
    </VBox>

    <GridPane hgap="16" vgap="16">
        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="metric-card" spacing="8">
            <Label text="Saldo total" styleClass="metric-label"/>
            <Label text="R$ 0,00" styleClass="metric-value"/>
        </VBox>
        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="metric-card" spacing="8">
            <Label text="Receitas do mês" styleClass="metric-label"/>
            <Label text="R$ 0,00" styleClass="metric-value income"/>
        </VBox>
        <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" styleClass="metric-card" spacing="8">
            <Label text="Despesas do mês" styleClass="metric-label"/>
            <Label text="R$ 0,00" styleClass="metric-value expense"/>
        </VBox>
    </GridPane>

    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox styleClass="panel" spacing="14" HBox.hgrow="ALWAYS">
            <Label text="Últimas transações" styleClass="panel-title"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Label text="Nenhuma transação registrada" styleClass="empty-state"/>
        </VBox>
        <VBox styleClass="panel" spacing="14" HBox.hgrow="ALWAYS">
            <Label text="Categorias em destaque" styleClass="panel-title"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Label text="Nenhuma categoria registrada" styleClass="empty-state"/>
        </VBox>
    </HBox>
</VBox>
