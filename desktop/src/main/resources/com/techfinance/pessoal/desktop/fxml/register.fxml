<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.techfinance.pessoal.desktop.controller.RegisterController"
            styleClass="register-root">

    <center>
        <VBox alignment="CENTER">

            <VBox styleClass="register-card" spacing="16">

                <padding>
                    <Insets top="32" right="32" bottom="32" left="32"/>
                </padding>

                <Label text="Criar conta"
                       styleClass="register-title"/>

                <Label text="Comece a organizar suas finanças"
                       styleClass="register-subtitle"/>

                <TextField fx:id="nameField"
                           promptText="Nome"
                           styleClass="register-field"/>

                <TextField fx:id="usernameField"
                           promptText="Username"
                           styleClass="register-field"/>

                <PasswordField fx:id="passwordField"
                               promptText="Senha"
                               styleClass="register-field"/>

                <Label fx:id="errorLabel"
                       visible="false"
                       managed="false"
                       styleClass="error-label"/>

                <Button text="Cadastrar"
                        onAction="#handleRegister"
                        styleClass="register-button"/>

                <Button text="Já tenho conta"
                        onAction="#goToLogin"
                        styleClass="register-link"/>

            </VBox>

        </VBox>
    </center>

</BorderPane>