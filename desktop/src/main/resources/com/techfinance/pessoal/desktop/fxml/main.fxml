<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.techfinance.pessoal.desktop.controller.MainController"
      styleClass="app-root"
      minWidth="1100"
      minHeight="700">

    <BorderPane styleClass="sidebar"
                minWidth="248"
                prefWidth="248"
                maxWidth="248">

        <top>
            <VBox spacing="28">
                <padding>
                    <Insets top="24" right="18" bottom="0" left="18"/>
                </padding>

                <VBox styleClass="brand-block">
                    <Label text="TechFinance" styleClass="brand-title"/>
                    <Label text="Controle financeiro pessoal" styleClass="brand-subtitle"/>
                </VBox>

                <VBox styleClass="sidebar-nav" spacing="8">
                    <Button fx:id="homeButton" text="Dashboard" onAction="#showHome"
                            styleClass="sidebar-button" maxWidth="Infinity"/>

                    <Button fx:id="accountsButton" text="Contas" onAction="#showAccounts"
                            styleClass="sidebar-button" maxWidth="Infinity"/>

                    <Button fx:id="transactionsButton" text="Transações" onAction="#showTransactions"
                            styleClass="sidebar-button" maxWidth="Infinity"/>

                    <Button fx:id="categoriesButton" text="Categorias" onAction="#showCategories"
                            styleClass="sidebar-button" maxWidth="Infinity"/>
                </VBox>
            </VBox>
        </top>

        <bottom>
            <VBox styleClass="user-block" spacing="4">
                <BorderPane.margin>
                    <Insets top="0" right="18" bottom="24" left="18"/>
                </BorderPane.margin>

                <Label fx:id="userNameLabel" text="Usuário" styleClass="user-name"/>
                <Label text="Usuário logado" styleClass="user-caption"/>

                <Button text="Sair"
                        onAction="#logout"
                        styleClass="logout-button"
                        maxWidth="Infinity"/>
            </VBox>
        </bottom>

    </BorderPane>

    <BorderPane HBox.hgrow="ALWAYS"
                styleClass="main-layout">

        <top>
            <HBox styleClass="topbar"
                  minHeight="64"
                  prefHeight="64"
                  alignment="CENTER_LEFT">

                <padding>
                    <Insets top="0" right="24" bottom="0" left="24"/>
                </padding>

                <Label text="Dashboard" styleClass="topbar-title"/>
            </HBox>
        </top>

        <center>
            <ScrollPane styleClass="content-scroll"
                        fitToWidth="true"
                        fitToHeight="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED">

                <StackPane fx:id="contentArea"
                           styleClass="content-area"
                           minWidth="0"
                           minHeight="0"
                           maxWidth="Infinity"
                           maxHeight="Infinity"/>
            </ScrollPane>
        </center>

    </BorderPane>

</HBox>