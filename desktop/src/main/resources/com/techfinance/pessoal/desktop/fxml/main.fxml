<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.techfinance.pessoal.desktop.controller.MainController"
            styleClass="app-root">

    <left>
        <VBox styleClass="sidebar" spacing="20">

            <padding>
                <Insets top="28" right="20" bottom="28" left="20"/>
            </padding>

            <VBox spacing="4">
                <Label text="TechFinance" styleClass="sidebar-title"/>
                <Label text="Controle financeiro pessoal" styleClass="sidebar-subtitle"/>
            </VBox>

            <VBox spacing="8">
                <Button text="Dashboard" onAction="#openDashboard" styleClass="sidebar-button"/>
                <Button text="Carteira" onAction="#openWallet" styleClass="sidebar-button"/>
                <Button text="Transações" onAction="#openTransactions" styleClass="sidebar-button"/>
                <Button text="Investimentos" onAction="#openInvestments" styleClass="sidebar-button"/>
                <Button text="Perfil" onAction="#openProfile" styleClass="sidebar-button"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="4" styleClass="sidebar-footer">
                <Label text="Saldo atual" styleClass="sidebar-footer-label"/>
                <Label text="R$ 4.500,00" styleClass="sidebar-footer-value"/>
            </VBox>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>

</BorderPane>