<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.techfinance.pessoal.desktop.controller.TransactionsController"
      spacing="20" styleClass="page">
    <padding>
        <Insets top="28" right="32" bottom="32" left="32"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label text="Transações" styleClass="page-title"/>
            <Label text="Lançamentos de receitas e despesas" styleClass="page-subtitle"/>
        </VBox>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button fx:id="createButton" text="Nova transação" styleClass="primary-button" onAction="#handleCreate"/>
    </HBox>

    <Label fx:id="errorLabel" visible="false" managed="false" styleClass="error-label"/>

    <TableView fx:id="transactionsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="dateColumn" text="Data" prefWidth="160"/>
            <TableColumn fx:id="descriptionColumn" text="Descrição" prefWidth="300"/>
            <TableColumn fx:id="accountColumn" text="Conta" prefWidth="180"/>
            <TableColumn fx:id="categoryColumn" text="Categoria" prefWidth="180"/>
            <TableColumn fx:id="typeColumn" text="Tipo" prefWidth="120"/>
            <TableColumn fx:id="amountColumn" text="Valor" prefWidth="140"/>
        </columns>
    </TableView>
</VBox>
